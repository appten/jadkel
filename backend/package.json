{
  "name": "jadkel-api",
  "version": "1.0.0",
  "description": "JadKel API - Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute jadkel-db --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute jadkel-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "wrangler": "^4.0.0"
  }
}
